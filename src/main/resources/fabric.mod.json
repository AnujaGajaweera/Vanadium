{
  "schemaVersion": 1,
  "id": "vim",
  "version": "${version}",
  "name": "Vim",
  "description": "Vulkan-native SPIR-V shader loader and manager for Minecraft via VulkanMod.",
  "authors": [
    "Vim Maintainers"
  ],
  "contact": {
    "email": "anujagajaweera@gmail.com",
    "homepage": "https://github.com/AnujaGajaweera/vim",
    "sources": "https://github.com/AnujaGajaweera/vim",
    "issues": "https://github.com/AnujaGajaweera/vim/issues"
  },
  "license": "${license}",
  "icon": "assets/vim/icon.png",
  "environment": "client",
  "entrypoints": {
    "main": [
      "net.vim.mod"
    ],
    "client": [
      "net.vim.VimClient"
    ]
  },
  "mixins": [
    "vim.mixins.json",
    {
      "config": "vim.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "minecraft": "~${minecraft_version}",
    "fabric-api": "*",
    "vulkanmod": "*"
  }
}
